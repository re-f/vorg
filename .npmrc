# 使用全局存储而不是项目本地存储
store-dir=~/.pnpm-store

# 使用硬链接（推荐，节省空间）
package-import-method=hardlink

# 备用方案: auto | clone | copy | clone-or-copy
# auto: 自动选择最佳方式
# hardlink: 硬链接（最快，最省空间）
# copy: 复制（兼容性最好）

# 可选：严格的对等依赖检查
strict-peer-dependencies=false

# 解决特定工具寻找依赖的问题，但不平展整个 node_modules
# 这会将匹配的包提升到根部，而保持其他包的隔离
public-hoist-pattern[]=*interpret*
public-hoist-pattern[]=*resolve-cwd*
public-hoist-pattern[]=*webpack-cli*


